          </widget>
         </item>
         <item>
          <spacer name="optionsRow1Spacer">
           <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
           <property name="sizeHint"><size><width>40</width><height>20</height></size></property>
