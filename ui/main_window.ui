    <!-- ================= Opções de execução ================= -->
    <item>
     <widget class="QGroupBox" name="groupOptions">
      <property name="title"><string>Opções de Execução</string></property>
      <layout class="QVBoxLayout" name="optionsOuterLayout">

       <item>
        <layout class="QHBoxLayout" name="optionsRow1">
         <item>
          <widget class="QCheckBox" name="checkShowPasswords">
           <property name="text"><string>Mostrar senhas na listagem</string></property>
          </widget>
         </item>
         <item>
          <widget class="QCheckBox" name="checkAutoRetry">
           <property name="text"><string>Reconectar automaticamente em caso de queda (a cada 5 min)</string></property>
