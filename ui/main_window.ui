           <property name="sizeHint"><size><width>40</width><height>20</height></size></property>
          </spacer>
         </item>
         <item>
          <widget class="QCheckBox" name="checkShutdownAfter">
           <property name="text"><string>Desligar o computador ao final da migração</string></property>
          </widget>
         </item>
        </layout>
       </item>

      </layout>
     </widget>
